<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.knowledge.controller.LoginController" spacing="10" alignment="CENTER" stylesheets="@../css/style-dark.css">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <Label text="KnowledgeApp" style="-fx-font-size:18px; -fx-font-weight:bold;" />
    <GridPane hgap="10" vgap="10">
        <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="usernameField" promptText="username" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <PasswordField fx:id="passwordField" promptText="password" GridPane.rowIndex="1" GridPane.columnIndex="1" />
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Login" onAction="#onLogin" fx:id="loginButton" />
        <Button text="Register" onAction="#onRegister" fx:id="registerButton" />
    </HBox>

    <Label fx:id="messageLabel" textFill="red" />
</VBox>
